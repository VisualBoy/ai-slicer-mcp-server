# PrusaSlicer executable path (e.g., "C:/Program Files/Prusa3D/PrusaSlicer/prusa-slicer-console.exe" or "/usr/bin/prusa-slicer")
PRUSA_SLICER_PATH=""

# Full path to the folder containing your 3D models (.stl, .obj, .3mf)
MODELS_FOLDER_PATH=""

# Full path to the folder where the generated .gcode files will be saved
GCODE_FOLDER_PATH=""

# URL of your OctoPrint instance (e.g., http://octopi.local or http://192.168.1.100)
OCTOPRINT_URL=""

# API Key from your OctoPrint settings
OCTOPRINT_API_KEY=""
